{
  "$schema": "./schema/pixiu.schema.json",
  "model": "openai-compatible/example-model",
  "providers": {
    "openai-compatible": {
      "baseURL": "https://api.example.com/v1",
      "apiKeyEnv": "PIXIU_OPENAI_COMPATIBLE_API_KEY"
    }
  },
  "agents": {
    "default": {
      "description": "Default coding and research agent.",
      "tools": ["read", "grep", "glob", "web_search", "web_fetch", "shell", "write", "edit", "patch", "todo", "skill_search", "skill"],
      "maxSteps": 20
    }
  },
  "permissions": {
    "read": "allow",
    "grep": "allow",
    "glob": "allow",
    "web_search": "ask",
    "web_fetch": "ask",
    "shell": "ask",
    "edit": "ask",
    "write": "ask",
    "skill_search": "allow"
  },
  "skills": {
    // Earlier roots win when duplicate skill names are discovered.
    // Default precedence: project .pixiu/skills, project .opencode/skills, Claude user skills, shared agent user skills.
    "paths": [".pixiu/skills", ".opencode/skills", "~/.claude/skills", "~/.agents/skills"]
  },
  "skillhub": {
    "baseURL": "https://www.skillhub.club",
    "apiKeyEnv": "SKILLHUB_API_KEY",
    "installDir": ".pixiu/skills"
  },
  "ui": {
    "accentColor": "#3B8EEA"
  },
  "mcp": {},
  "sandbox": {
    "mode": "workspace",
    "workspaceDir": "workspace",
    "workspaceOnly": true,
    "shellTimeoutMs": 30000,
    "outputMaxBytes": 20000,
    "envAllowlist": ["PATH", "HOME", "USER", "LANG", "LC_ALL", "SHELL", "TMPDIR"]
  },
  "compaction": {
    "maxApproxTokens": 64000,
    "keepRecentMessages": 12
  }
}
