{
  "$schema": "./schema/pixiu.schema.json",
  "model": "deepseek-ai/DeepSeek-V4-Flash",
  "providers": {
    "openai-compatible": {
      "baseURL": "https://api.siliconflow.cn/v1",
      "type": "openai-compatible",
      "apiKey": "sk-yayshjcwlttywmjqeudokdsfxbieqijgvlrnzirxayqluqrs"
    }
  },
  "agents": {
    "default": {
      "description": "Default coding and research agent.",
      "tools": [
        "read",
        "grep",
        "glob",
        "shell",
        "write",
        "edit",
        "patch",
        "todo",
        "skill"
      ],
      "maxSteps": 20
    }
  },
  "permissions": {
    "read": "allow",
    "grep": "allow",
    "glob": "allow",
    "shell": "ask",
    "edit": "ask",
    "write": "ask"
  },
  "skills": {
    "paths": [
      ".pixiu/skills",
      ".opencode/skills",
      "~/.claude/skills",
      "~/.agents/skills"
    ]
  },
  "skillhub": {
    "baseURL": "https://www.skillhub.club",
    "apiKeyEnv": "SKILLHUB_API_KEY",
    "installDir": ".pixiu/skills"
  },
  "ui": {
    "accentColor": "#3B8EEA"
  },
  "mcp": {},
  "sandbox": {
    "mode": "workspace",
    "workspaceDir": "workspace",
    "workspaceOnly": true,
    "shellTimeoutMs": 30000,
    "outputMaxBytes": 20000,
    "envAllowlist": [
      "PATH",
      "HOME",
      "USER",
      "LANG",
      "LC_ALL",
      "SHELL",
      "TMPDIR"
    ]
  },
  "compaction": {
    "maxApproxTokens": 64000,
    "keepRecentMessages": 12
  }
}
